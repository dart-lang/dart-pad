{
  "name": "codemirror-lang-dart",
  "version": "0.0.1",
  "description": "Dart language support for CodeMirror 6 using the Dart analyzer.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node -e \"require('fs').mkdirSync('test/dist',{recursive:true})\" && dart compile js -Dnode=true -O2 test/dart_test_env.dart -o test/dist/dart_impl.cjs && mocha --node-option loader=ts-node/esm test/test-*.ts"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/codemirror": "^5.60.15",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "mocha": "^11.7.5",
    "rollup": "^4.14.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.4.4"
  },
  "dependencies": {
    "@codemirror/language": "^6.10.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.26.0",
    "@lezer/common": "^1.2.1",
    "@lezer/highlight": "^1.2.0",
    "@lezer/javascript": "^1.5.4",
    "codemirror": "^6.0.1",
    "puppeteer": "^24.42.0",
    "puppeteer-core": "^24.42.0"
  }
}