{
  "name": "codemirror-dart",
  "version": "0.0.1",
  "description": "CodeMirror 6 support for Dart.",
  "private": true,
  "type": "module",
  "license": "BSD-3-Clause",
  "scripts": {
    "build": "node tool/build.js",
    "format:check": "prettier --check \"{src,test,tool}/**/*.{html,js,ts}\" README.md package.json rollup.config.mjs tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/lsp-client": "^6.2.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@lezer/common": "^1.2.1",
    "@lezer/highlight": "^1.2.0",
    "@lezer/javascript": "^1.5.4",
    "codemirror": "^6.0.2",
    "codemirror-lang-dart": "file:../codemirror-lang-dart"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.17.0",
    "prettier": "^3.6.2",
    "rollup": "^4.60.2",
    "rollup-plugin-license": "^3.7.1",
    "tslib": "^2.8.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  }
}
